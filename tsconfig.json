{
  "compilerOptions": {
    // Compilation target
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    "outDir": "dist",
    "rootDir": "src",

    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,

    "removeComments": true,
    "sourceMap": false,
    "inlineSourceMap": false,

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts"]
}
